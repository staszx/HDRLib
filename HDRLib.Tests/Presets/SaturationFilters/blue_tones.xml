<?xml version="1.0" encoding="utf-8"?>
<SaturationColorFilter xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>Blue tones</Name>
  <Description>Reduces saturation in blue hues.</Description>
  <Enabled>false</Enabled>
  <SaturationAdjustment>-20</SaturationAdjustment>
  <Ranges>
    <SaturationColorRange>
      <HueMin>205</HueMin>
      <HueMax>255</HueMax>
      <SaturationMin>0.18</SaturationMin>
      <SaturationMax>1</SaturationMax>
      <ValueMin>0.08</ValueMin>
      <ValueMax>1</ValueMax>
      <SaturationMultiplier>-20</SaturationMultiplier>
    </SaturationColorRange>
  </Ranges>
</SaturationColorFilter>
