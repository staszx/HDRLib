<?xml version="1.0" encoding="utf-8"?>
<SaturationColorFilter xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>Sky control</Name>
  <Description>Reduces saturation in cyan-blue sky hues to avoid neon skies.</Description>
  <Enabled>false</Enabled>
  <SaturationAdjustment>-18</SaturationAdjustment>
  <Ranges>
    <SaturationColorRange>
      <HueMin>175</HueMin>
      <HueMax>245</HueMax>
      <SaturationMin>0.18</SaturationMin>
      <SaturationMax>1</SaturationMax>
      <ValueMin>0.35</ValueMin>
      <ValueMax>1</ValueMax>
      <SaturationMultiplier>-18</SaturationMultiplier>
    </SaturationColorRange>
    <SaturationColorRange>
      <HueMin>190</HueMin>
      <HueMax>225</HueMax>
      <SaturationMin>0.12</SaturationMin>
      <SaturationMax>0.75</SaturationMax>
      <ValueMin>0.45</ValueMin>
      <ValueMax>1</ValueMax>
      <SaturationMultiplier>-18</SaturationMultiplier>
    </SaturationColorRange>
    <SaturationColorRange>
      <HueMin>225</HueMin>
      <HueMax>255</HueMax>
      <SaturationMin>0.16</SaturationMin>
      <SaturationMax>0.90</SaturationMax>
      <ValueMin>0.32</ValueMin>
      <ValueMax>1</ValueMax>
      <SaturationMultiplier>-18</SaturationMultiplier>
    </SaturationColorRange>
  </Ranges>
</SaturationColorFilter>
